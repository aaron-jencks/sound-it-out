{
  "model": {
    "model_name": "google/byt5-small",
    "tokenizer_name": "google/byt5-small",
    "hyperparameters": {
      "weight_decay": 0.01,
      "num_train_epochs": 3,
      "per_device_train_batch_size": 8,
      "per_device_eval_batch_size": 8,
      "learning_rate": 5e-5,
      "lr_scheduler_type": "cosine",
      "warmup_steps": 0.1,
      "torch_compile": true
    },
    "checkpoint_prefix": "checkpoints",
    "generation": {
      "max_length": 256,
      "max_new_tokens": 128,
      "do_sample": false,
      "num_beams": 4
    }
  },
  "dataset": {
    "definitions": [],
    "samples": 100000,
    "shuffle_buffer": 10000,
    "hf_cache": "./cache/huggingface",
    "input_feature": "ipa",
    "output_feature": "text",
    "train_split_size": 0.8,
    "output_dataset_name": "constructed_ipa_dataset",
    "force_dataset_build": false,
    "language_separators": {}
  },
  "wandb": {
    "project": "ipa-p2g"
  },
  "random_seed": 42
}