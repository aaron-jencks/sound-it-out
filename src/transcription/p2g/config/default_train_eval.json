{
  "model": {
    "model_name": "google/byt5-small",
    "tokenizer": {
      "name": "google/byt5-small",
      "max_sequence_length": 1024
    },
    "hyperparameters": {
      "weight_decay": 0.01,
      "num_train_epochs": 3,
      "per_device_train_batch_size": 32,
      "per_device_eval_batch_size": 128,
      "learning_rate": 5e-5,
      "lr_scheduler_type": "cosine",
      "warmup_ratio": 0.1,
      "torch_compile": true,
      "bf16": true,
      "eval_strategy": "steps",
      "eval_steps": 0.1,
      "save_strategy": "steps",
      "save_steps": 0.1,
      "save_total_limit": 2,
      "metric_for_best_model": "bleu",
      "logging_steps": 0.01
    },
    "generation": {
      "max_new_tokens": 128,
      "do_sample": false,
      "num_beams": 4
    },
    "supports_bf16": true,
    "checkpoint_prefix": "transcription/p2g/checkpoints"
  },
  "results_prefix": "transcription/p2g/results",
  "wandb": {
    "enabled": true,
    "project": "ipa-p2g",
    "settings": {}
  },
  "train_dataset": {
    "output_feature": "text",
    "language_feature": "language",
    "split": "train",
    "languages": [
      "en-us", "es",
      "ru", "pl",
      "hi", "ur",
      "ml", "ta"
    ],
    "language_map": {
      "en-us": "en"
    }
  },
  "evaluation_dataset": {
    "output_feature": "text",
    "language_feature": "language",
    "split": "test",
    "languages": [
      "en-us", "es",
      "ru", "pl",
      "hi", "ur",
      "ml", "ta"
    ],
    "language_map": {
      "en-us": "en"
    }
  }
}
